<UserControl x:Class="AstroPM.NINA.Plugin.Views.NightlyChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="230">
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Padding="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="38"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="190"/>
                <RowDefinition Height="20"/>
            </Grid.RowDefinitions>
            <Canvas x:Name="FilterBarCanvas" Grid.Row="0" Grid.Column="1" ClipToBounds="True"/>
            <Canvas x:Name="YAxisCanvas" Grid.Row="1" Grid.Column="0" ClipToBounds="True"/>
            <Canvas x:Name="TimelineCanvas" Grid.Row="1" Grid.Column="1" ClipToBounds="True"
                    SizeChanged="TimelineCanvas_SizeChanged"
                    MouseLeftButtonDown="Scrubber_MouseDown"
                    MouseMove="Scrubber_MouseMove"
                    MouseLeftButtonUp="Scrubber_MouseUp"/>
            <Canvas x:Name="TimeAxisBottom" Grid.Row="2" Grid.Column="1" Height="20" ClipToBounds="True"/>
            <TextBlock x:Name="TxtEmpty" Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Run the instruction to generate the nightly schedule chart."
                       FontSize="12" Foreground="#555555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
