<ResourceDictionary
    x:Class="AstroPM.NINA.Plugin.Views.SequenceTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AstroPM.NINA.Plugin.Instructions"
    xmlns:views="clr-namespace:AstroPM.NINA.Plugin.Views"
    xmlns:nina="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer"
    xmlns:mini="clr-namespace:NINA.View.Sequencer.MiniSequencer;assembly=NINA.Sequencer">

    <DataTemplate DataType="{x:Type local:TargetInstructionSet}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="0,2" Background="{DynamicResource TertiaryBackgroundBrush}">
                    <!-- Live status -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}" CornerRadius="3" Padding="8,5" Margin="0,2,0,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasLiveStatus}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel>
                            <!-- Reset button — top right -->
                            <Button DockPanel.Dock="Right" Command="{Binding ResetScheduleCommand}"
                                    Content="⟲ Reset" FontSize="9" Padding="6,2"
                                    VerticalAlignment="Center" Cursor="Hand"
                                    Background="Transparent"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    ToolTip="Clear schedule and re-fetch targets on next run"/>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{DynamicResource NotificationWarningBrush}" CornerRadius="2" Padding="6,2" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Status:" FontSize="10" FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7"/>
                                        <TextBlock Text="{Binding LiveCommand}" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryBrush}" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Target -->
                                <TextBlock Text="Target:" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6"/>
                                <TextBlock Text="{Binding LiveTarget}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <!-- Filter -->
                                <TextBlock Text="Filter:" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6"/>
                                <TextBlock Text="{Binding LiveFilter}" FontSize="11"
                                           Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <!-- Exposure -->
                                <TextBlock Text="Exposure:" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6"/>
                                <TextBlock Text="{Binding LiveExposure}" FontSize="11"
                                           Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <!-- Camera -->
                                <TextBlock Text="Camera:" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6"/>
                                <TextBlock Text="{Binding LiveGainOffset}" FontSize="10"
                                           Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <!-- Coordinates -->
                                <TextBlock Text="Coordinates:" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="RA {0}  DEC {1}">
                                            <Binding Path="LiveRA"/>
                                            <Binding Path="LiveDEC"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <!-- Rotation -->
                                <TextBlock Text="Rotation:" FontSize="10" Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="8,0,4,0" Opacity="0.6"/>
                                <TextBlock Text="{Binding LiveRotation}" FontSize="10"
                                           Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Start Now button — DEBUG ONLY, uncomment for local testing, remove before deploying
                    <Button Command="{Binding StartNowCommand}" Content="&#9654; Start Now"
                            FontSize="10" Padding="10,3" Margin="0,4,0,0"
                            HorizontalAlignment="Left" Cursor="Hand"
                            Background="{DynamicResource NotificationWarningBrush}"
                            Foreground="{DynamicResource ButtonForegroundBrush}"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LiveCommand}" Value="Waiting">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    -->

                    <!-- Blocks heading -->
                    <TextBlock Text="Tonight's Scheduled Targets" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,6,0,2"/>


                    <!-- Block List -->
                    <ItemsControl ItemsSource="{Binding BlockSummaries}" Margin="0,2,0,0"
                                  Grid.IsSharedSizeScope="True">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasBlockInfo}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="8,4" Margin="0,1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ColTarget"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ColTime"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ColStatus"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ColSubs"/>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ColMeridian"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Current indicator -->
                                        <TextBlock Grid.Column="0" Text="&#9654;" FontSize="8"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                                   Foreground="{DynamicResource ButtonForegroundBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Block number + target -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Number, StringFormat='#{0}'}" FontSize="10"
                                                       Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                                       Margin="0,0,6,0" MinWidth="18"/>
                                            <TextBlock Text="{Binding TargetName}" FontSize="10"
                                                       VerticalAlignment="Center" MinWidth="180">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <!-- Time range -->
                                        <TextBlock Grid.Column="2" Text="{Binding TimeRange}" FontSize="10"
                                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <!-- Status -->
                                        <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="9" FontStyle="Italic"
                                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                                   Margin="0,0,12,0" MinWidth="60"/>
                                        <!-- Sub count -->
                                        <TextBlock Grid.Column="4" Text="{Binding SubCountDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                                   Margin="0,0,12,0" MinWidth="50"/>
                                        <!-- Meridian transit -->
                                        <TextBlock Grid.Column="5" Text="{Binding MeridianInfo}" FontSize="9"
                                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                                   FontStyle="Italic" Margin="12,0,20,0"/>
                                        <!-- Coords -->
                                        <TextBlock Grid.Column="6" Text="{Binding Coords}" FontSize="9"
                                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                        <!-- Load to Framing button -->
                                        <Button Grid.Column="7" Cursor="Hand" ToolTip="View in Framing Assistant"
                                                Margin="8,0,0,0" Padding="2" VerticalAlignment="Center"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.LoadToFramingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="M0,0 L3,0 L3,1 L1,1 L1,3 L0,3 Z M9,0 L12,0 L12,3 L11,3 L11,1 L9,1 Z M12,9 L12,12 L9,12 L9,11 L11,11 L11,9 Z M0,9 L0,12 L3,12 L3,11 L1,11 L1,9 Z"
                                                  Fill="{DynamicResource PrimaryBrush}" Width="12" Height="12"
                                                  Stretch="Uniform" Opacity="0.7"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Graph heading -->
                    <TextBlock Text="Nightly Simulation Graph" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,8,0,2"/>

                    <views:NightlyChartControl Margin="0,2,0,0"
                        Visibility="Collapsed"
                        ScrubberEnabled="False"
                        Tag="{Binding}" Loaded="NightlyChart_Loaded" />

                    <!-- Log heading (collapsible) -->
                    <Expander IsExpanded="False" Margin="0,8,0,0" Background="Transparent" BorderThickness="0">
                        <Expander.Style>
                            <Style TargetType="Expander">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasChartData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Expander.Style>
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Target Instructions" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                <CheckBox Content="Auto-scroll" IsChecked="{Binding AutoScrollLog}"
                                          Margin="16,0,0,0" VerticalAlignment="Center"
                                          FontSize="10" Foreground="{DynamicResource PrimaryBrush}" Opacity="0.7"/>
                            </StackPanel>
                        </Expander.Header>
                        <!-- Simulation Log -->
                        <ListView ItemsSource="{Binding LogEntries}"
                                  SelectedItem="{Binding ActiveLogEntry, Mode=OneWay}"
                                  MaxHeight="240" Margin="0,4,0,0"
                                  Background="Transparent" BorderThickness="0"
                                  Foreground="{DynamicResource PrimaryBrush}" FontSize="10" FontFamily="Consolas"
                                  ScrollViewer.CanContentScroll="True"
                                  Loaded="LogList_Loaded">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Padding" Value="1,0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="MinHeight" Value="18"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                                      Columns="{TemplateBinding GridView.ColumnCollection}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="GridViewColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="Padding" Value="2,1"/>
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="GridViewColumnHeader">
                                                    <Border Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>
                                <GridViewColumn Header="Cmd" Width="65" DisplayMemberBinding="{Binding Command}"/>
                                <GridViewColumn Header="Time" Width="55" DisplayMemberBinding="{Binding Time}"/>
                                <GridViewColumn Header="Target" Width="210" DisplayMemberBinding="{Binding Target}"/>
                                <GridViewColumn Header="Panel" Width="45" DisplayMemberBinding="{Binding Panel}"/>
                                <GridViewColumn Header="#" Width="35" DisplayMemberBinding="{Binding SubNum}"/>
                                <GridViewColumn Header="Filter" Width="60" DisplayMemberBinding="{Binding Filter}"/>
                                <GridViewColumn Header="Exp" Width="50" DisplayMemberBinding="{Binding Exposure}"/>
                                <GridViewColumn Header="Gain" Width="40" DisplayMemberBinding="{Binding Gain}"/>
                                <GridViewColumn Header="Offset" Width="45" DisplayMemberBinding="{Binding Offset}"/>
                                <GridViewColumn Header="Bin" Width="35" DisplayMemberBinding="{Binding Bin}"/>
                            </GridView>
                        </ListView.View>
                        </ListView>
                    </Expander>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="AstroPM.NINA.Plugin.Instructions.TargetInstructionSet_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Astro PM Instructions" />
                </StackPanel>
                </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!--  RefreshCloudTargets — Full View                            -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <DataTemplate DataType="{x:Type local:RefreshCloudTargets}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="0,2">
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <!-- Green/Red indicator -->
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource SecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FetchSuccess}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding FetchSuccess}" Value="False">
                                            <Setter Property="Fill" Value="#E74C3C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding TargetCount, StringFormat='{}{0} targets'}" FontSize="10"
                                   Foreground="{DynamicResource PrimaryBrush}" Opacity="0.6"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding LastFetchTime}" FontSize="10"
                                   Foreground="{DynamicResource PrimaryBrush}" Opacity="0.5"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="AstroPM.NINA.Plugin.Instructions.RefreshCloudTargets_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource SecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FetchSuccess}" Value="True">
                                        <Setter Property="Fill" Value="#22C55E"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FetchSuccess}" Value="False">
                                        <Setter Property="Fill" Value="#E74C3C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="AstroPM Refresh Cloud Targets" />
                </StackPanel>
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!--  Before Each Exposure Instructions                          -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <DataTemplate DataType="{x:Type local:AstroPMBeforeExposureTrigger}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="0,2">
                    <TextBlock Text="Runs before each AstroPM exposure" FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource PrimaryBrush}" Opacity="0.5" Margin="0,0,0,4"/>
                    <ContentPresenter Content="{Binding TriggerRunner}" Margin="0,2,0,0"/>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>
    <DataTemplate x:Key="AstroPM.NINA.Plugin.Instructions.AstroPMBeforeExposureTrigger_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <TextBlock Text="Before Each Exposure Instructions" />
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!--  After Each Exposure Instructions                           -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <DataTemplate DataType="{x:Type local:AstroPMAfterExposureTrigger}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="0,2">
                    <TextBlock Text="Runs after each AstroPM exposure" FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource PrimaryBrush}" Opacity="0.5" Margin="0,0,0,4"/>
                    <ContentPresenter Content="{Binding TriggerRunner}" Margin="0,2,0,0"/>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>
    <DataTemplate x:Key="AstroPM.NINA.Plugin.Instructions.AstroPMAfterExposureTrigger_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <TextBlock Text="After Each Exposure Instructions" />
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!--  Before Target Change Instructions                          -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <DataTemplate DataType="{x:Type local:AstroPMBeforeTargetTrigger}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="0,2">
                    <TextBlock Text="Runs before AstroPM slews to each new target" FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource PrimaryBrush}" Opacity="0.5" Margin="0,0,0,4"/>
                    <ContentPresenter Content="{Binding TriggerRunner}" Margin="0,2,0,0"/>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>
    <DataTemplate x:Key="AstroPM.NINA.Plugin.Instructions.AstroPMBeforeTargetTrigger_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <TextBlock Text="Before Target Change Instructions" />
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <!-- ════════════════════════════════════════════════════════════ -->
    <!--  After Target Change Instructions                           -->
    <!-- ════════════════════════════════════════════════════════════ -->
    <DataTemplate DataType="{x:Type local:AstroPMAfterTargetTrigger}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical" Margin="0,2">
                    <TextBlock Text="Runs after AstroPM finishes each target block" FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource PrimaryBrush}" Opacity="0.5" Margin="0,0,0,4"/>
                    <ContentPresenter Content="{Binding TriggerRunner}" Margin="0,2,0,0"/>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>
    <DataTemplate x:Key="AstroPM.NINA.Plugin.Instructions.AstroPMAfterTargetTrigger_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <TextBlock Text="After Target Change Instructions" />
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

</ResourceDictionary>
