<UserControl x:Class="AstroPM.NINA.Plugin.Views.SimulatorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AstroPM.NINA.Plugin.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="SimBtn" TargetType="Button" BasedOn="{StaticResource StandardButton}">
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="12,6" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="Margin" Value="4,8,0,6"/>
        </Style>

        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- ═══ Cloud Cache Status ═══ -->
        <StackPanel Orientation="Horizontal" Margin="4,0,0,6">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#E74C3C"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CacheAvailable}" Value="True">
                                <Setter Property="Fill" Value="#22C55E"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{Binding CacheStatusText}" FontSize="11"
                       Foreground="{DynamicResource PrimaryBrush}" Opacity="0.7"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ═══ Header Bar: Date + Simulate ═══ -->
        <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                CornerRadius="4" Padding="16,12" Margin="0,0,0,8">
            <WrapPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                    <TextBlock Text="DATE" Style="{StaticResource SettingsLabel}"/>
                    <Button Content="&#9664;" Style="{StaticResource SimBtn}" Width="32" MinWidth="32"
                            MinHeight="24" FontSize="11" Padding="0"
                            Command="{Binding DatePrevCommand}"/>
                    <TextBlock Text="{Binding DateDisplay}" Width="90" TextAlignment="Center"
                               FontSize="13" Foreground="{DynamicResource PrimaryBrush}"
                               VerticalAlignment="Center" Margin="4,0"/>
                    <Button Content="&#9654;" Style="{StaticResource SimBtn}" Width="32" MinWidth="32"
                            MinHeight="24" FontSize="11" Padding="0"
                            Command="{Binding DateNextCommand}"/>
                    <Button Content="Tonight" Style="{StaticResource SimBtn}" MinWidth="50"
                            FontSize="11" Padding="8,0" Margin="4,0,0,0" Command="{Binding DateTodayCommand}"/>
                </StackPanel>

                <Button Content="Simulate" Style="{StaticResource SimBtn}" MinWidth="100"
                        FontSize="12" FontWeight="SemiBold"
                        Command="{Binding SimulateCommand}" Margin="0,0,0,4"/>
            </WrapPanel>
        </Border>

        <!-- Status text when no results -->
        <TextBlock Text="{Binding StatusText}" FontSize="12"
                   Foreground="{DynamicResource PrimaryBrush}" Opacity="0.6"
                   Margin="4,0,0,8"
                   Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse, FallbackValue=Visible}"/>

        <!-- ═══ Step 1: Simulator Strategy & Settings ═══ -->
        <TextBlock Text="Step 1.  Simulator Strategy &amp; Settings" Style="{StaticResource StepHeading}"/>

        <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                CornerRadius="4" Padding="16,12" Margin="0,0,0,8">
            <StackPanel>
                <ComboBox Width="320" HorizontalAlignment="Left" Margin="0,0,0,6"
                          ItemsSource="{Binding StrategyOptions}"
                          DisplayMemberPath="Value" SelectedValuePath="Key"
                          SelectedValue="{Binding Strategy, Mode=TwoWay}"/>
                <TextBlock Text="{Binding StrategyDescription}" FontSize="11" Foreground="#888888"
                           TextWrapping="Wrap"/>

                <Border Height="1" Background="#333333" Margin="0,10,0,10"/>

                <WrapPanel VerticalAlignment="Center">
                    <!-- Bonus images -->
                    <TextBlock Text="Bonus Images" FontSize="11" Foreground="#AAAAAA"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <CheckBox IsChecked="{Binding BonusImagesEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              ToolTip="Continue capturing exposures past requested amount if no other targets are available"/>

                    <Border Width="1" Background="#333333" Margin="16,2,16,2" VerticalAlignment="Stretch"/>

                    <!-- Mosaic panel preference -->
                    <TextBlock Text="Mosaic Panels Independently" FontSize="11" Foreground="#AAAAAA"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <CheckBox IsChecked="{Binding MosaicPanelPreference, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              ToolTip="Treat each mosaic panel as a separate target so each gets its own time block"/>

                    <Border Width="1" Background="#333333" Margin="16,2,16,2" VerticalAlignment="Stretch"/>

                    <!-- Dither settings -->
                    <TextBlock Text="Dither" FontSize="11" Foreground="#AAAAAA"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <CheckBox IsChecked="{Binding DitherEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="every" FontSize="11" Foreground="#888888"
                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ComboBox Width="45" SelectedItem="{Binding DitherEvery, Mode=TwoWay}"
                              IsEnabled="{Binding DitherEnabled}" VerticalAlignment="Center">
                        <ComboBox.Items>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">1</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">2</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">3</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">4</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">5</sys:Int32>
                        </ComboBox.Items>
                    </ComboBox>
                    <TextBlock Text="subs" FontSize="11" Foreground="#888888"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>

                    <Border Width="1" Background="#333333" Margin="16,2,16,2" VerticalAlignment="Stretch"/>

                    <!-- Filter switch settings -->
                    <TextBlock Text="Filter switch" FontSize="11" Foreground="#AAAAAA"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <CheckBox IsChecked="{Binding FilterSwitchEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="every" FontSize="11" Foreground="#888888"
                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox Width="40" Text="{Binding FilterSwitchCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding FilterSwitchEnabled}" VerticalAlignment="Center"
                             TextAlignment="Center"/>
                    <TextBlock Text="subs" FontSize="11" Foreground="#888888"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <TextBlock Text="tolerance" FontSize="11" Foreground="#888888"
                               VerticalAlignment="Center" Margin="14,0,4,0"/>
                    <ComboBox Width="60" VerticalAlignment="Center"
                              IsEnabled="{Binding FilterSwitchEnabled}"
                              ItemsSource="{Binding ToleranceOptions}"
                              DisplayMemberPath="Value" SelectedValuePath="Key"
                              SelectedValue="{Binding FilterSwitchTolerance, Mode=TwoWay}"
                              ToolTip="A filter switch may only start a filter that can fit at least this percentage of the switch count in its remaining runway (target time or moon-safety window)"/>

                </WrapPanel>

                <!-- Sort Chain — drag-to-reorder priority -->
                <Border Height="1" Background="#333333" Margin="0,10,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="SCHEDULING PRIORITY" FontSize="10" FontWeight="SemiBold"
                               Foreground="#007ACC" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="drag to reorder" FontSize="10" Foreground="#666666"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ItemsControl ItemsSource="{Binding SortChainItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252525" BorderBrush="#444444" BorderThickness="1"
                                        CornerRadius="10" Padding="10,4" Margin="3,0"
                                        Cursor="Hand" AllowDrop="True"
                                        MouseMove="SortChip_MouseMove"
                                        DragEnter="SortChip_DragEnter"
                                        DragOver="SortChip_DragOver"
                                        Drop="SortChip_Drop">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Index}" FontSize="10" Foreground="#4FC3F7"
                                                   FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Label}" FontSize="11" Foreground="#CCCCCC"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <TextBlock Text="Scheduling priority affects how targets are ordered when multiple compete for the same time window."
                           FontSize="10" Foreground="#555555" TextWrapping="Wrap" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ Step 2: Nightly Targets ═══ -->
        <StackPanel Orientation="Horizontal"
                    Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Step 2.  Nightly Targets" Style="{StaticResource StepHeading}"/>
            <TextBlock Text="{Binding PriorityHint}" FontSize="11" Foreground="#666666"
                       VerticalAlignment="Center" Margin="6,0,0,4"/>
        </StackPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                      Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"
                      Margin="0,0,0,8">
            <ItemsControl ItemsSource="{Binding TargetCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                                CornerRadius="4" Padding="10,14,10,14" Margin="0,0,8,8" Width="420">
                            <StackPanel>
                                <!-- Target name + color dot + priority badge -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Ellipse Width="10" Height="10" Fill="{Binding ColorBrush}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#DCDCDC"/>
                                    <Border Background="#007ACC" CornerRadius="8" Padding="6,1"
                                            Margin="8,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding PriorityBadgeVisibility}">
                                        <TextBlock Text="{Binding PriorityBadge}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>

                                <!-- Stats grid (vertical like AstroPM) -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Allocated:" FontSize="11"
                                               Foreground="#888888" Margin="0,0,8,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AllocatedTime}" FontSize="11"
                                               Foreground="#CCCCCC"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Window:" FontSize="11"
                                               Foreground="#888888" Margin="0,0,8,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Window}" FontSize="11"
                                               Foreground="#CCCCCC"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Altitude:" FontSize="11"
                                               Foreground="#888888" Margin="0,0,8,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AltitudeRange}" FontSize="11"
                                               Foreground="#CCCCCC"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Moon sep:" FontSize="11"
                                               Foreground="#888888" Margin="0,0,8,2"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MoonSeparation}" FontSize="11"
                                               Foreground="#CCCCCC"/>
                                </Grid>

                                <!-- Remaining exposures header -->
                                <TextBlock Text="REMAINING EXPOSURES" FontSize="9" FontWeight="SemiBold"
                                           Foreground="#888888" Margin="0,4,0,4" Opacity="0.6"/>

                                <!-- Panel tabs (mosaic projects only) -->
                                <ItemsControl ItemsSource="{Binding PanelNames}" Visibility="{Binding IsMultiPanel}"
                                              Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="8,3" Margin="0,0,4,0"
                                                    Background="{Binding Background}" BorderThickness="1"
                                                    BorderBrush="{Binding BorderColor}"
                                                    Cursor="Hand" MouseLeftButtonDown="SimPanelTab_Click">
                                                <TextBlock Text="{Binding Label}" FontSize="9" FontWeight="SemiBold"
                                                           Foreground="{Binding Foreground}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Filter rows with status icon + colored chip + detail -->
                                <ItemsControl ItemsSource="{Binding VisibleFilters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="42"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="10"
                                                           FontWeight="Bold" Foreground="{Binding StatusColor}"
                                                           VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Background="{Binding ChipColor}" CornerRadius="3"
                                                        Padding="4,2" MinWidth="36" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding FilterLabel}" FontSize="9"
                                                               Foreground="White" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding ExposureDetail}" FontSize="10"
                                                           Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- LA definition -->
                                <TextBlock Text="LA = Lunar Avoidance" FontSize="9" Foreground="#666666"
                                           FontStyle="Italic" Margin="0,4,0,0"
                                           Visibility="{Binding LaDefinitionVisibility}"/>

                                <!-- Constraint checks -->
                                <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,6,0,0">
                                    <ItemsControl ItemsSource="{Binding ConstraintChecks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                                                    <TextBlock Text="{Binding Icon}" FontSize="11" FontWeight="Bold"
                                                               Foreground="{Binding IconColor}"
                                                               VerticalAlignment="Center" Width="16"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="10"
                                                               Foreground="#888888" VerticalAlignment="Center"
                                                               Width="80"/>
                                                    <TextBlock Text="{Binding Detail}" FontSize="10"
                                                               Foreground="{Binding DetailColor}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══ Step 3: Nightly Graph Simulation ═══ -->
        <Grid Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}" Margin="4,8,0,6">
            <TextBlock Text="Step 3.  Nightly Graph Simulation" FontSize="13" FontWeight="SemiBold"
                       Foreground="#007ACC" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SummaryText}" FontSize="11"
                       Foreground="{DynamicResource PrimaryBrush}" Opacity="0.6"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>
        </Grid>

        <!-- ═══ Current Instruction ═══ -->
        <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,8"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Command badge -->
                <Border Grid.Column="0" Background="#007ACC" CornerRadius="3"
                        Padding="10,4" VerticalAlignment="Center" Margin="0,0,14,0">
                    <TextBlock Text="{Binding CurrentInstructionCommand}" FontSize="12" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" MinWidth="50" TextAlignment="Center"/>
                </Border>

                <!-- Info grid -->
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <!-- Target -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="TARGET" FontSize="9" FontWeight="SemiBold" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentInstructionTarget}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#DCDCDC" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Panel -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="PANEL" FontSize="9" FontWeight="SemiBold" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentInstructionPanel}" FontSize="11"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Sub -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="SUB" FontSize="9" FontWeight="SemiBold" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentInstructionSub}" FontSize="11"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Filter -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="FILTER" FontSize="9" FontWeight="SemiBold" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentInstructionFilter}" FontSize="11"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Exposure -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="EXP" FontSize="9" FontWeight="SemiBold" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentInstructionExposure}" FontSize="11"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Gain/Offset/Bin -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="{Binding CurrentInstructionGainOffset}" FontSize="11"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- RA -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="RA" FontSize="9" FontWeight="SemiBold" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentInstructionRA}" FontSize="11"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- DEC -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="DEC" FontSize="9" FontWeight="SemiBold" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentInstructionDEC}" FontSize="11"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Rotation -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <TextBlock Text="ROT" FontSize="9" FontWeight="SemiBold" Foreground="#666666"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentInstructionRotation}" FontSize="11"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <views:NightlyChartControl x:Name="SimChart" Margin="0,0,0,8"
                                   Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"/>

        <!-- ═══ Simulation Log ═══ -->
        <TextBlock Text="Simulation Log" Style="{StaticResource StepHeading}"
                   Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"/>

        <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                CornerRadius="4" Padding="8" Margin="0,0,0,8"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Copy Log button -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="Copy Log" Style="{StaticResource SimBtn}" MinWidth="80"
                            Click="BtnCopyLog_Click"/>
                </StackPanel>

                <!-- Log table -->
                <ListView Grid.Row="1" x:Name="SimLogList" Height="280"
                          ItemsSource="{Binding LogEntries}"
                          SelectedItem="{Binding SelectedLogEntry, Mode=TwoWay}"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#CCCCCC" FontSize="11" FontFamily="Consolas"
                          SelectionChanged="SimLogList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="2,1"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                            <GridViewRowPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A3050"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A4060"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Command" Width="70" DisplayMemberBinding="{Binding Command}"/>
                            <GridViewColumn Header="Time" Width="55" DisplayMemberBinding="{Binding Time}"/>
                            <GridViewColumn Header="Target" Width="200" DisplayMemberBinding="{Binding Target}"/>
                            <GridViewColumn Header="Panel" Width="45" DisplayMemberBinding="{Binding Panel}"/>
                            <GridViewColumn Header="Sub" Width="45" DisplayMemberBinding="{Binding SubNum}"/>
                            <GridViewColumn Header="Filter" Width="55" DisplayMemberBinding="{Binding Filter}"/>
                            <GridViewColumn Header="Exp" Width="50" DisplayMemberBinding="{Binding Exposure}"/>
                            <GridViewColumn Header="Gain" Width="45" DisplayMemberBinding="{Binding Gain}"/>
                            <GridViewColumn Header="Offset" Width="50" DisplayMemberBinding="{Binding Offset}"/>
                            <GridViewColumn Header="Bin" Width="35" DisplayMemberBinding="{Binding Bin}"/>
                            <GridViewColumn Header="Rot" Width="45" DisplayMemberBinding="{Binding Rotation}"/>
                            <GridViewColumn Header="RA" Width="95" DisplayMemberBinding="{Binding RA}"/>
                            <GridViewColumn Header="DEC" Width="95" DisplayMemberBinding="{Binding DEC}"/>
                            <GridViewColumn Header="Sort 1" Width="55" DisplayMemberBinding="{Binding Sort1}"/>
                            <GridViewColumn Header="Sort 2" Width="55" DisplayMemberBinding="{Binding Sort2}"/>
                            <GridViewColumn Header="Sort 3" Width="55" DisplayMemberBinding="{Binding Sort3}"/>
                            <GridViewColumn Header="Sort 4" Width="55" DisplayMemberBinding="{Binding Sort4}"/>
                            <GridViewColumn Header="Alt" Width="45" DisplayMemberBinding="{Binding Altitude}"/>
                            <GridViewColumn Header="Moon Sep" Width="65" DisplayMemberBinding="{Binding MoonSep}"/>
                            <GridViewColumn Header="Moon OK" Width="60" DisplayMemberBinding="{Binding MoonSafe}"/>
                            <GridViewColumn Header="Avoid Sep" Width="65" DisplayMemberBinding="{Binding MoonAvoidSep}"/>
                            <GridViewColumn Header="Dark" Width="45" DisplayMemberBinding="{Binding DarkSafe}"/>
                            <GridViewColumn Header="LA" Width="40" DisplayMemberBinding="{Binding LaEnabled}"/>
                            <GridViewColumn Header="LA Safe" Width="55" DisplayMemberBinding="{Binding LaSafe}"/>
                            <GridViewColumn Header="Filter Profile" Width="95" DisplayMemberBinding="{Binding FilterProfile}"/>
                            <GridViewColumn Header="Accepted Profiles" Width="175" DisplayMemberBinding="{Binding AcceptedProfiles}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
